{
  "info": {
    "_postman_id": "9235166d-f778-4ed1-b723-0370a28cc8c2",
    "name": "Opticare Clinic - Image Timeline",
    "description": "Image timeline, folders, comparison, notes, and report attachment endpoints. Set the collection variables before running requests. All endpoints require Sanctum bearer authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is successful', function () {",
          "    pm.expect(pm.response.code).to.be.within(200, 299);",
          "});",
          "pm.test('Response is JSON', function () {",
          "    pm.response.to.be.json;",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "patient_id",
      "value": "1"
    },
    {
      "key": "image_type",
      "value": "OCT"
    },
    {
      "key": "folder_id",
      "value": "1"
    },
    {
      "key": "left_folder_id",
      "value": "1"
    },
    {
      "key": "right_folder_id",
      "value": "2"
    },
    {
      "key": "file_id",
      "value": "1"
    },
    {
      "key": "left_file_id",
      "value": "1"
    },
    {
      "key": "right_file_id",
      "value": "2"
    },
    {
      "key": "report_id",
      "value": "1"
    },
    {
      "key": "visit_id",
      "value": "1"
    },
    {
      "key": "visit_record_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Browse Image Timeline",
      "item": [
        {
          "name": "List Patient Image Types",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/medical-records/patients/{{patient_id}}/image-types?date_from=2026-01-01&date_to=2026-12-31",
              "host": ["{{base_url}}"],
              "path": ["api", "medical-records", "patients", "{{patient_id}}", "image-types"],
              "query": [
                {
                  "key": "date_from",
                  "value": "2026-01-01",
                  "disabled": true
                },
                {
                  "key": "date_to",
                  "value": "2026-12-31",
                  "disabled": true
                }
              ]
            },
            "description": "Returns available resolved image types for the patient. Date filters are optional."
          },
          "response": []
        },
        {
          "name": "List Patient Image Folders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/medical-records/patients/{{patient_id}}/image-folders?image_type={{image_type}}&eye=OD&region=Macula&status=completed&date_from=2026-01-01&date_to=2026-12-31&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "medical-records", "patients", "{{patient_id}}", "image-folders"],
              "query": [
                {
                  "key": "image_type",
                  "value": "{{image_type}}"
                },
                {
                  "key": "eye",
                  "value": "OD",
                  "disabled": true
                },
                {
                  "key": "region",
                  "value": "Macula",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "completed"
                },
                {
                  "key": "date_from",
                  "value": "2026-01-01",
                  "disabled": true
                },
                {
                  "key": "date_to",
                  "value": "2026-12-31",
                  "disabled": true
                },
                {
                  "key": "per_page",
                  "value": "20"
                }
              ]
            },
            "description": "Lists paginated imaging-request folders. Optional filters: image_type, eye (OD/OS/OU), region, status, date_from, date_to, and per_page."
          },
          "response": []
        },
        {
          "name": "Get Folder Files",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/medical-records/image-folders/{{folder_id}}/files?image_type={{image_type}}&eye=OD&region=Macula",
              "host": ["{{base_url}}"],
              "path": ["api", "medical-records", "image-folders", "{{folder_id}}", "files"],
              "query": [
                {
                  "key": "image_type",
                  "value": "{{image_type}}",
                  "disabled": true
                },
                {
                  "key": "eye",
                  "value": "OD",
                  "disabled": true
                },
                {
                  "key": "region",
                  "value": "Macula",
                  "disabled": true
                }
              ]
            },
            "description": "Returns folder metadata plus grouped and flat image files. All query filters are optional."
          },
          "response": []
        },
        {
          "name": "Get Single Image Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/medical-records/imaging-files/{{file_id}}",
            "description": "Returns image metadata, URLs, folder details, and the authenticated doctor's note."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Compare Images",
      "item": [
        {
          "name": "Compare Two Folders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/medical-records/patients/{{patient_id}}/image-comparison?image_type={{image_type}}&left_folder_id={{left_folder_id}}&right_folder_id={{right_folder_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "medical-records", "patients", "{{patient_id}}", "image-comparison"],
              "query": [
                {
                  "key": "image_type",
                  "value": "{{image_type}}"
                },
                {
                  "key": "left_folder_id",
                  "value": "{{left_folder_id}}"
                },
                {
                  "key": "right_folder_id",
                  "value": "{{right_folder_id}}"
                }
              ]
            },
            "description": "Returns same-image-type candidate files from two different patient folders."
          },
          "response": []
        },
        {
          "name": "Compare Two Specific Files",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/medical-records/patients/{{patient_id}}/image-comparison/files?left_file_id={{left_file_id}}&right_file_id={{right_file_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "medical-records", "patients", "{{patient_id}}", "image-comparison", "files"],
              "query": [
                {
                  "key": "left_file_id",
                  "value": "{{left_file_id}}"
                },
                {
                  "key": "right_file_id",
                  "value": "{{right_file_id}}"
                }
              ]
            },
            "description": "Validates and returns two same-type files with same_eye and same_region indicators."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Image Notes",
      "item": [
        {
          "name": "Save or Update Image Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"There is visible improvement compared with the previous OCT.\",\n  \"visit_record_id\": {{visit_record_id}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/medical-records/imaging-files/{{file_id}}/notes",
            "description": "Creates or updates the authenticated doctor's note. Remove visit_record_id if it is not applicable. Send an empty or null note to clear it."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Attach Images To Report",
      "item": [
        {
          "name": "Append Selected Images and Folders",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"append\",\n  \"imaging_file_ids\": [{{file_id}}],\n  \"imaging_request_ids\": [{{folder_id}}]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/medical-records/reports/{{report_id}}/images",
            "description": "Appends individual files and all files from selected folders. At least one non-empty ID array is required."
          },
          "response": []
        },
        {
          "name": "Replace Report Images",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"replace\",\n  \"imaging_file_ids\": [{{file_id}}]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/medical-records/reports/{{report_id}}/images",
            "description": "Removes the report's existing image links, then attaches the selected files and folders."
          },
          "response": []
        },
        {
          "name": "Save Visit Report With Selected Images",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"report\": {\n    \"title\": \"Follow-up Report\",\n    \"report_text\": \"OCT reviewed with the patient.\",\n    \"selected_image_ids\": [{{file_id}}],\n    \"selected_folder_ids\": [{{folder_id}}]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/medical-records/visits/{{visit_id}}/save-session",
            "description": "Creates or updates the visit report and links selected individual images and whole folders."
          },
          "response": []
        }
      ]
    }
  ]
}
