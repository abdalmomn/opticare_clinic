  "item": [
    {
      "name": "Imaging Requests",
      "item": [
        {
          "name": "List Imaging Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/imaging/requests",
              "host": ["{{base_url}}"],
              "path": ["api", "imaging", "requests"],
              "query": [
                { "key": "status", "value": "requested", "disabled": true, "description": "requested, pending_payment, payment_confirmed, ready_for_imaging, in_progress, completed, cancelled, pending, canceled" },
                { "key": "payment_status", "value": "pending", "disabled": true, "description": "pending, confirmed, waived, refunded" },
                { "key": "patient_id", "value": "{{patient_id}}", "disabled": true },
                { "key": "requested_by", "value": "{{requested_by}}", "disabled": true },
                { "key": "technician_id", "value": "{{technician_id}}", "disabled": true },
                { "key": "priority", "value": "normal", "disabled": true, "description": "normal or urgent" },
                { "key": "date_from", "value": "{{date_from}}", "disabled": true },
                { "key": "date_to", "value": "{{date_to}}", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "per_page", "value": "15", "disabled": true },
                { "key": "page", "value": "1", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Imaging Request",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
                "const id = json?.data?.id;",
                "if (id) pm.collectionVariables.set('imaging_request_id', id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": {{patient_id}},\n  \"visit_record_id\": {{visit_record_id}},\n  \"appointment_id\": {{appointment_id}},\n  \"requested_by\": {{requested_by}},\n  \"room_id\": {{room_id}},\n  \"notes\": \"OCT requested during examination\",\n  \"priority\": \"normal\",\n  \"requested_types\": [\n    {\n      \"image_type\": \"OCT\",\n      \"eye\": \"left\",\n      \"region\": \"macula\",\n      \"notes\": \"Macular scan\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/imaging/requests"
          }
        },
        {
          "name": "Show Imaging Request",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/imaging/requests/{{imaging_request_id}}"
          }
        },
        {
          "name": "Cancel Imaging Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Patient requested cancellation\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/imaging/requests/{{imaging_request_id}}/cancel"
          }
        },
        {
          "name": "Confirm Imaging Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoice_item_id\": {{invoice_item_id}},\n  \"waive\": false,\n  \"notes\": \"Payment confirmed\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/imaging/requests/{{imaging_request_id}}/confirm-payment"
          }
        },
        {
          "name": "Waive Imaging Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"waive\": true,\n  \"notes\": \"Payment waived by authorized staff\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/imaging/requests/{{imaging_request_id}}/confirm-payment"
          }
        },
        {
          "name": "Send Request To Technician",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"technician_id\": {{technician_id}},\n  \"room_id\": {{room_id}},\n  \"priority\": \"normal\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/imaging/requests/{{imaging_request_id}}/send-to-technician"
          }
        }
      ]
    },
    {
