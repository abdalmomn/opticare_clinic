{
  "info": {
    "_postman_id": "7da432ba-76fb-45be-929a-70472c90cdf1",
    "name": "Opticare Clinic - Imaging",
    "description": "Complete collection for app/Modules/Imaging/Routes/api.php. All routes require Sanctum bearer authentication. Set token and entity ID variables before use. Optional query parameters are included but disabled. Multipart requests contain one file/metadata pair; add matching files[n] and metadata[n][...] fields for additional files.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is successful', function () {",
          "    pm.expect(pm.response.code).to.be.within(200, 299);",
          "});",
          "pm.test('Response is JSON', function () {",
          "    pm.response.to.be.json;",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "imaging_request_id", "value": "1" },
    { "key": "imaging_file_id", "value": "1" },
    { "key": "imaging_request_item_id", "value": "1" },
